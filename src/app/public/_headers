# Cloudflare Pages response headers.
#
# The service worker and HTML entry must always be revalidated, or an edge/browser
# cache can keep serving an old sw.js and the update prompt (UpdateBanner) never
# fires. Hashed assets under /assets/ are immutable and cache forever by default, so
# only these entry points opt out.
/sw.js
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/manifest.webmanifest
  Cache-Control: no-cache
