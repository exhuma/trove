# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Both values below are build-time: Vite inlines every VITE_-prefixed var into the
# client bundle at `vite build`. That is expected here.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# The PUBLISHABLE key (sb_publishable_…, the current replacement for the legacy anon
# key). It is public by design — it ships to every browser and per-user security comes
# from Postgres RLS, not from hiding it.
VITE_SUPABASE_PUBLISHABLE_KEY=

# ⚠️  NEVER put the secret key (sb_secret_… / service_role) in any VITE_ var or in a
#     .env that reaches the client build. It bypasses RLS and belongs only server-side.

# Optional. Overrides the release channel shown in the UI's version chip. Normally
# the channel is derived from the git tag at build time (a pre-release tag like
# v2026.07.0-beta.1 → "beta"; a clean tag → "production"; an untagged build → "dev"),
# so you rarely set this. Use it to force a label, e.g. to publish a "beta" build from
# an untagged commit. The chip is hidden entirely when the channel is "production".
VITE_APP_CHANNEL=

# Dev-only backend switch. Set VITE_BACKEND=memory (typically in a gitignored
# .env.local) to run the app with an in-memory store and a stub auth session — no
# Supabase project, credentials, or network needed, no login step. Ideal for a quick
# UI dev loop. It is hard-gated to `import.meta.env.DEV`, so it is inert in any
# `vite build`: production always uses Supabase regardless of this value. Leave unset
# (or anything other than `memory`) to use Supabase in dev too.
VITE_BACKEND=

# The Supabase *CLI* (schema migrations, `task db:push`) authenticates with a
# SUPABASE_ACCESS_TOKEN and a project ref — supplied in your shell environment,
# not here. These are operator/deploy credentials, never VITE_-prefixed (they must
# not reach the client bundle) and never committed. The migration workflow lives in
# supabase/README.md.

# Cloudflare Pages PROJECT name, used by `task deploy`.
#
# This is the project name, not the .pages.dev subdomain — the two differ when the
# subdomain you asked for is already taken globally, in which case Cloudflare suffixes
# the domain and leaves the project name alone. `trove` is served from
# trove-c9g.pages.dev for exactly that reason.
#
# Getting this wrong fails silently in the worst way: `wrangler pages deploy` creates a
# brand-new project under whatever name it is given rather than erroring, so the deploy
# "succeeds" while the live site goes untouched. `npx wrangler pages project list` shows
# both columns if you need to check.
PAGES_PROJECT=trove
